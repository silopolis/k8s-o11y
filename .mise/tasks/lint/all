#!/usr/bin/env bash
# [MISE] description="Run all linting checks (markdownlint + shellcheck)"
# [MISE] depends=["lint:markdown", "lint:shell"]

set -e

# Source the lint library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../../../lib/lint.sh"

echo "=== Running all lint checks ==="

# Check that tools are available
lint_check_tools || exit 1

echo ""
echo "=== Running markdown linting ==="
lint_markdown || true

echo ""
echo "=== Running shellcheck ==="
lint_shell || true

echo ""
echo "=== All lint checks complete ==="
