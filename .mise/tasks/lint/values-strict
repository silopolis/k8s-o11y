#!/usr/bin/env bash
# [MISE] description="Strict lint of Phase 01-02 values with Helm schema validation"

set -e

echo "Pulling kube-prometheus-stack chart for validation..."
CHART_DIR=$(mktemp -d)
helm pull prometheus-community/kube-prometheus-stack --untar --untardir "$CHART_DIR"
echo "Validating values against chart schema..."
helm lint "$CHART_DIR/kube-prometheus-stack" \
  --values values/kube-prometheus-stack.yaml \
  --values values/prometheus.yaml \
  --values values/grafana.yaml \
  --values values/alertmanager.yaml
LINT_EXIT=$?
rm -rf "$CHART_DIR"
exit $LINT_EXIT
